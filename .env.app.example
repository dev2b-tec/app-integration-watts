# =============================================================================
# app-integration-watts — variáveis de ambiente
# Copie este arquivo para .env (local) ou use como base para o secret APP_ENV
# do GitHub Actions.
# O arquivo .env NÃO deve ser commitado (já está no .gitignore).
# =============================================================================

SERVER_PORT=8012

# PostgreSQL
DB_URL=jdbc:postgresql://postgres:5432/app_whats
DB_USER=postgres
DB_PASSWORD=TROQUE_PELA_SENHA_REAL

# Evolution API
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=TROQUE_PELA_CHAVE_REAL

# Webhook — URL pública deste serviço (usada para registrar na Evolution API)
WEBHOOK_BASE_URL=https://whats-api.dev2b.tec.br

# CORS — origens permitidas para WebSocket
CORS_ALLOWED_ORIGINS=https://app.dev2b.tec.br
